<!DOCTYPE html><html><head><meta name="viewport" content="initial-scale=1.0"><meta charset="utf-8"><style>  html, body, #map{  margin:0;  padding:0;  width:100%;  height:100vh;  }  
  #infoBox{  position:absolute;  top:10px;  left:10px;  background:white;  padding:10px;  font-family:Arial;  border-radius:6px;  box-shadow:0 2px 6px rgba(0,0,0,0.3);  z-index:1000;  }  </style><script src="https://sdk.mappls.com/map/sdk/web?v=3.0&access_token=cxnpqzxawukwpajjqvwfatzjavgzrcxoxsqp&callback=initMap" defer async></script></head><body><div id="map"></div><div id="infoBox">Speed: 0 km/h<br>
Distance Today: 0 km<br>
Last Update: --
</div><script>  
  var map;  var marker;  var path=[];  var polyline;  
  var prevLat=null;  var prevLon=null;  var prevTime=null;  
  var dailyDistance=0;  var currentDay=new Date().getDate();  
  function initMap(){  
      map=new mappls.Map('map',{          center:[28.61,77.23],          zoom:15      });  
      marker=new mappls.Marker({          map:map,          position:{lat:28.61,lng:77.23}      });  
      polyline=new mappls.Polyline({          map:map,          path:path, // Initially empty path          strokeColor:"#8B4513",          strokeWeight:4      });  
      /* load route history and then start live updates */      loadHistory().then(() => {          console.log("DEBUG: --- History Loaded ---");          // Log the full path after history load          console.log("DEBUG: Path after loadHistory:", path.map(p => ({lat: p.lat.toFixed(6), lng: p.lng.toFixed(6)})));          console.log("DEBUG: Number of points after loadHistory:", path.length);          // Start live updates only AFTER history has fully loaded and its data processed          setInterval(updateLocation, 15000);      }).catch(error => {          console.error("DEBUG: Error loading history:", error);          // If history fails to load, you might still want to start live updates          setInterval(updateLocation, 15000);      });  }  
  /* LIVE LOCATION */  
  function updateLocation(){      fetch("https://api.thingspeak.com/channels/3290360/feeds/last.json?api_key=5MSDTN7LSUQHD3AN")      .then(r=>r.json())      .then(data=>{          var lat=parseFloat(data.field1);          var lon=parseFloat(data.field2);          // --- MODIFICATION START ---          var speed=parseFloat(data.field3); // Get speed directly from field3          if (isNaN(speed)) {              speed = 0; // Default to 0 if field3 is not a valid number              console.warn("DEBUG: Invalid speed received from ThingSpeak field3, defaulting to 0.");          }          // --- MODIFICATION END ---  
          if(isNaN(lat)||isNaN(lon)) {              console.warn("DEBUG: Invalid latitude or longitude from updateLocation fetch.");              return;          }  
          var now=new Date();  
          /* reset distance at midnight */          if(now.getDate()!=currentDay){              dailyDistance=0;              currentDay=now.getDate();          }  
          /* move marker */          marker.setPosition({lat:lat,lng:lon});          map.setCenter({lat:lat,lng:lon});  
          /* calculate movement distance */          var moveDist=0;          if(prevLat!=null){              moveDist=distance(prevLat,prevLon,lat,lon);          }  
          /* ignore GPS noise under 10m */          if(prevLat==null || moveDist>10){              path.push({lat:lat,lng:lon});              polyline.setPath(path);  
              // Debug log for updated path segment              console.log("DEBUG: --- updateLocation Executed ---");              console.log("DEBUG: New point added:", {lat: lat.toFixed(6), lng: lon.toFixed(6)});              console.log("DEBUG: Path after updateLocation (last 2 points):", path.slice(-2).map(p => ({lat: p.lat.toFixed(6), lng: p.lng.toFixed(6)})));              console.log("DEBUG: Number of points after updateLocation:", path.length);  
              /* add to daily distance */              if(prevLat!=null){                  dailyDistance+=moveDist;              }          } else {               console.log("DEBUG: Point ignored (GPS noise < 10m):", {lat: lat.toFixed(6), lng: lon.toFixed(6)});          }  
          /* store previous point */          prevLat=lat;          prevLon=lon;          prevTime=now;  
          /* update info box */          document.getElementById("infoBox").innerHTML=              "Speed: "+speed.toFixed(1)+" km/h<br>"+ // Use the fetched speed              "Distance Today: "+(dailyDistance/1000).toFixed(2)+" km<br>"+              "Last Update: "+now.toLocaleTimeString();  
      })      .catch(error => {          console.error("DEBUG: Error in updateLocation fetch:", error);      });  }  
  /* LOAD HISTORY */  
  function loadHistory(){      // Return the Promise so initMap can await its completion      return fetch("https://api.thingspeak.com/channels/3290360/feeds.json?api_key=5MSDTN7LSUQHD3AN&days=1")      .then(r=>r.json())      .then(data=>{          data.feeds.forEach(point=>{              var lat=parseFloat(point.field1);              var lon=parseFloat(point.field2);              if(!isNaN(lat)&&!isNaN(lon)){                  path.push({lat:lat,lng:lon});              }          });          polyline.setPath(path); // Update polyline with historical path  
          /* move marker to last history point */          if(path.length>0){              var last=path[path.length-1];              marker.setPosition(last);              map.setCenter(last);              prevLat=last.lat;              prevLon=last.lng;              prevTime=new Date(); // Set prevTime to current time or the timestamp of the last history point if available          }      });  }  
  /* DISTANCE CALCULATION */  
  function distance(lat1,lon1,lat2,lon2){      var R=6371000; // Earth's radius in meters      var dLat=(lat2-lat1)*Math.PI/180;      var dLon=(lon2-lon1)*Math.PI/180;      var a=Math.sin(dLat/2)*Math.sin(dLat/2)+          Math.cos(lat1*Math.PI/180)*          Math.cos(lat2*Math.PI/180)*          Math.sin(dLon/2)*Math.sin(dLon/2);      var c=2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));      return R*c;  }  
  </script></body></html>
